#!/usr/bin/env bash
# agentbox CLI — container lifecycle + devcontainer management for AI agent sandboxes.
#
# Usage:
#   agentbox              # start container + enter interactive shell
#   agentbox opencode     # start container + launch OpenCode TUI
#   agentbox claude       # start container + launch Claude Code
#   agentbox run <cmd>    # start container + exec <cmd>
#   agentbox start        # ensure container is running
#   agentbox stop         # stop container (session-aware)
#   agentbox rebuild      # force full rebuild
#   agentbox clean        # remove container + volumes + state
#   agentbox status       # show container state
#
# Set AGENTBOX_HOME to override the installation directory.
# Default: parent directory of this script (i.e. the agentbox repo root).

set -euo pipefail

# Resolve the agentbox installation root (one level above bin/).
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
AGENTBOX_HOME="${AGENTBOX_HOME:-$(cd "$SCRIPT_DIR/.." && pwd)}"
PROJECT_DIR="${AGENTBOX_PROJECT_DIR:-$PWD}"
PROJECT_NAME="${AGENTBOX_PROJECT_NAME:-$(basename "$PROJECT_DIR")}"
export PROJECT_DIR PROJECT_NAME

# Source library modules (relative to this script)
LIB_DIR="$(cd "$SCRIPT_DIR/../lib" && pwd)"

source "$LIB_DIR/volume.sh"
source "$LIB_DIR/devcontainer.sh"
source "$LIB_DIR/session.sh"
source "$LIB_DIR/container.sh"
source "$LIB_DIR/migration.sh"

# ── helpers ──────────────────────────────────────────────────────────────

_usage() {
    cat <<'EOF'
agentbox — AI agent sandbox with declarative environment.

Usage:
  agentbox                 Start container + enter shell (interactive)
  agentbox opencode        Start container + launch OpenCode TUI
  agentbox claude          Start container + launch Claude Code
  agentbox run <cmd...>    Start container + run command

  agentbox start           Ensure container is running (background)
  agentbox stop            Stop container (session-aware)
  agentbox rebuild         Force rebuild image + recreate container
  agentbox clean           Remove container, volumes, and state
  agentbox status          Show container status
  agentbox migration run <version>
                          Run a migration script manually (no version change)
  agentbox migration baseline <version>
                          Set baseline version for next auto-migration
EOF
}

_die() {
    echo "[agentbox] ERROR: $*" >&2
    exit 1
}

# ── session-aware exec wrapper ───────────────────────────────────────────

# Run a command inside the container with session tracking.
# On exit, remove the session marker and stop the container if no sessions remain.
_run_with_session() {
    local cmd=("$@")

    container_start
    session_register

    trap '_session_cleanup' EXIT

    _compose exec -it agent "${cmd[@]}"
}

_session_cleanup() {
    session_unregister
    if ! session_has_active; then
        container_stop
    fi
}

# ── command dispatch ─────────────────────────────────────────────────────

main() {
    # Ensure we're in the agentbox directory so compose files resolve
    cd "$AGENTBOX_HOME"

    # Skip auto-migration for manual migration subcommand
    if [ "${1:-}" != "migration" ]; then
        migration_check || _die "Migration failed — fix the error above and retry."
    fi

    case "${1:-}" in
        # ── migration (manual control) ──
        migration)
            shift
            case "${1:-}" in
                run)
                    shift
                    migration_run "${1:?Usage: agentbox migration run <version>}"
                    ;;
                baseline)
                    shift
                    migration_baseline "${1:?Usage: agentbox migration baseline <version>}"
                    ;;
                *)
                    echo "Current version: $(_migration_read_version)"
                    echo "Target version:  $AGENTBOX_MIGRATION_VERSION"
                    ;;
            esac
            ;;

        # ── high-level (session-aware) ──
        "")
            _run_with_session bash
            ;;
        opencode)
            _run_with_session opencode
            ;;
        claude)
            _run_with_session bash -c 'exec claude --dangerously-skip-permissions "$@"' -- "$@"
            ;;
        run)
            shift
            _run_with_session "$@"
            ;;
        exec)
            shift
            container_start
            _compose exec -T agent "$@"
            ;;

        # ── low-level (container management) ──
        start)
            container_start
            echo "[agentbox] Container ready: $COMPOSE_PROJECT"
            ;;
        stop)
            container_stop
            ;;
        rebuild)
            container_rebuild
            ;;
        clean)
            container_clean
            ;;
        status)
            container_status
            ;;

        # ── help ──
        -h|--help|help)
            _usage
            ;;
        *)
            _die "Unknown command: $1 (use -h for help)"
            ;;
    esac
}

main "$@"

# Copy to .env (keep it next to the compose files, NEVER inside a project repo).
#   cp .env.example .env && chmod 600 .env

# === Provider ===
# OpenCode + omo are pinned to DeepSeek V4 Pro — set its key here:
DEEPSEEK_API_KEY=sk-...

# Gemini provider — used by multimodal agents (image/PDF recognition):
GEMINI_API_KEY=...

# Claude Code provider (independent of OpenCode):
# Option A — direct Anthropic API key:
ANTHROPIC_API_KEY=sk-ant-...

# Option B — internal / Anthropic-compatible gateway (comment out A, use these):
# ANTHROPIC_BASE_URL=https://your-gateway.internal/anthropic
# ANTHROPIC_AUTH_TOKEN=your-gateway-token
# ANTHROPIC_MODEL=claude-sonnet-4-6

# === Version pinning ===
# Reproducible, deliberate upgrades. Prefer EXACT versions over 'latest' once you have
# a known-good build; bump them on purpose and rebuild to upgrade.
CLAUDE_CODE_VERSION=latest
OPENCODE_VERSION=latest
CODEX_VERSION=latest
